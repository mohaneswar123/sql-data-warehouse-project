

/*
Script Purpose : creation of tables according to the Bronze Layer

Warning : By running this script all existing tables will get droped anlong with data
and new tables will be created

*/

use DataWarehouseProject

--1
if OBJECT_ID ('silver.crm_cust_info','U') is not null
	drop table silver.crm_cust_info
create table silver.crm_cust_info(
	cust_id int,
	cust_key nvarchar(50),
	cst_firstname nvarchar(50),
	cst_lastname nvarchar(50),
	cst_marital_status nvarchar(50),
	cst_gndr nvarchar(10),
	cst_create_date datetime,
	dwh_create_date datetime2 default  getdate()
);

--2
if OBJECT_ID ('silver.crm_prd_info','U') is not null
	drop table silver.crm_prd_info
create table silver.crm_prd_info(
	prd_id int,
	ctg_id nvarchar(20),
	prd_key nvarchar(50),
	prd_nm nvarchar(50),
	prd_cost int,
	prd_line nvarchar(50),
	prd_start_dt date,
	prd_end_dt date,
	dwh_create_date datetime2 default  getdate()
);

